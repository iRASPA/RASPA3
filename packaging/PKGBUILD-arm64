pkgname=raspa
pkgver=3.0.22
pkgrel=1
pkgdesc="Molecular simulation code for adsorption and diffusion in nanoporours materials."
arch=('aarch64')
url="https://www.iraspa.org"
license=('MIT')
makedepends=()
depends=('glibc' 'blas64' 'lapack64' 'gcc-libs' 'openmp' 'hdf5')
source=(raspa3.tar.gz)
md5sums=('SKIP')

build() {
  cmake -B build --preset linux-aarch64-archlinux -DCMAKE_INSTALL_PREFIX=${pkgdir}/usr -DCMAKE_POLICY_VERSION_MINIMUM=3.5 
  cmake --build build
}

package() {
  cmake --install build 
}

